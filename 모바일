// ── 뉴스 렌더링 ──────────────────────────────────
function renderNews() {
  const icons = {호재:'🟢',악재:'🔴',중립:'⚪'};
  const bCls  = {호재:'nb-pos',악재:'nb-neg',중립:'nb-neu'};
  let html = NEWS_DATA.map(n => `
    <div class="news-item">
      <div class="news-hl">${icons[n.impact]} ${n.hl}</div>
      <div class="news-meta">
        <span class="news-src">${n.src} · ${n.time}</span>
        <span class="news-badge ${bCls[n.impact]}">${n.impact}</span>
        ${n.tags.map(t=>`<span style="font-size:9px;color:#444;">#${t}</span>`).join('')}
      </div>
    </div>`).join('');
  document.getElementById('news-list').innerHTML = html;

  let fhtml = FIGURES_DATA.map(f => `
    <div class="fig-item">
      <div class="fig-top">
        <div class="fig-av">${f.name[0]}</div>
        <div><div class="fig-name">${f.name}</div><div class="fig-role">${f.role}</div></div>
        <span class="fig-time">${f.time}</span>
      </div>
      <div class="fig-quote">"${f.quote}"</div>
    </div>`).join('');
  document.getElementById('figure-list').innerHTML = fhtml;
}

// ── 시간 업데이트 ────────────────────────────────
function updateTime() {
  const now = new Date();
  document.getElementById('update-time').textContent =
    now.getHours().toString().padStart(2,'0') + ':' +
    now.getMinutes().toString().padStart(2,'0') + ' 갱신';
}

function refreshAll() {
  renderHeatmap();
  renderStockList();
  updateTime();
}

// ── 초기화 ───────────────────────────────────────
renderHeatmap();
renderStockList();
renderPotential();
renderSectors();
renderCoins();
renderCommodities();
renderFX();
renderNews();
updateTime();
setInterval(updateTime, 60000);
</script>
