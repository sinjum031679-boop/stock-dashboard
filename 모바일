    <div class="det-price">현재가 ${priceStr}</div>
    <div class="det-chart">
      <svg width="100%" height="80" viewBox="0 0 300 80">
        <polygon points="0,60 30,55 60,62 90,48 120,38 150,42 180,30 210,22 240,18 270,15 300,12 300,80 0,80" fill="rgba(39,174,96,.1)"/>
        <polyline points="0,60 30,55 60,62 90,48 120,38 150,42 180,30 210,22 240,18 270,15 300,12" stroke="#27ae60" stroke-width="1.5" fill="none"/>
