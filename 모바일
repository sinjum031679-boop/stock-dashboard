<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="theme-color" content="#0d0d1a">
<title>Kang's View</title>
<link rel="manifest" href="manifest.json">
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
body{background:#0d0d1a;color:#cdd6f4;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;overflow:hidden;height:100dvh;display:flex;flex-direction:column;}
.pos{color:#27ae60;}.neg{color:#e74c3c;}

/* 헤더 */
.header{background:#1a1a2e;padding:8px 12px 6px;border-bottom:0.5px solid #2a2a3e;flex-shrink:0;display:flex;align-items:center;justify-content:space-between;}
.header-left .title{font-size:14px;font-weight:500;}
.header-left .maker{font-size:9px;color:#555;}
.header-right{display:flex;align-items:center;gap:6px;}
.refresh-btn{font-size:10px;padding:3px 8px;border-radius:4px;border:0.5px solid #2a2a3e;background:transparent;color:#888;cursor:pointer;}
.update-time{font-size:9px;color:#444;}

/* 서브탭 (미국주식: SP500/나스닥) */
.subtab-bar{display:flex;background:#1a1a2e;border-bottom:0.5px solid #2a2a3e;flex-shrink:0;}
.subtab{flex:1;text-align:center;padding:5px 0;font-size:10px;color:#555;border-bottom:2px solid transparent;cursor:pointer;}
.subtab.on{color:#cdd6f4;border-bottom-color:#cdd6f4;}

/* 요약바 */
.sum-bar{display:flex;align-items:center;justify-content:space-around;padding:4px 10px;background:#1a1a2e;border-bottom:0.5px solid #2a2a3e;flex-shrink:0;}
.sum-item{display:flex;align-items:center;gap:3px;}
.sum-val{font-size:10px;font-weight:500;}
.sum-lbl{font-size:8px;color:#444;}
.sum-div{width:0.5px;height:10px;background:#2a2a3e;}

/* 메인 콘텐츠 */
.content{flex:1;overflow-y:auto;overflow-x:hidden;}

/* 히트맵 */
.heatmap-wrap{padding:6px;}
.hm-grid{display:grid;grid-template-columns:1fr 1fr;gap:3px;height:calc(100dvh - 200px);}
.hm-sector{border-radius:4px;position:relative;padding:11px 2px 2px;overflow:hidden;}
.hm-sec-lbl{position:absolute;top:2px;left:4px;font-size:7px;color:rgba(255,255,255,.4);font-weight:500;}
.hm-cells{display:grid;grid-template-columns:1fr 1fr;gap:1.5px;height:100%;}
.hm-cell{border-radius:2px;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;transition:opacity .1s;}
.hm-cell:active{opacity:.75;}
.hm-t{font-size:8px;font-weight:500;color:white;line-height:1.2;}
.hm-k{font-size:7px;color:rgba(255,255,255,.8);line-height:1.2;}
.hm-p{font-size:7px;color:rgba(255,255,255,.9);}

/* 종목 리스트 */
.search-bar{padding:6px 10px;border-bottom:0.5px solid #2a2a3e;background:#1a1a2e;}
.search-input{width:100%;background:#0d0d1a;border:0.5px solid #2a2a3e;border-radius:6px;padding:6px 10px;font-size:12px;color:#cdd6f4;outline:none;}
.filter-bar{display:flex;gap:4px;padding:4px 10px;border-bottom:0.5px solid #2a2a3e;background:#1a1a2e;overflow-x:auto;}
.filter-bar::-webkit-scrollbar{display:none;}
.fb{font-size:9px;padding:2px 7px;border-radius:4px;border:0.5px solid #2a2a3e;background:transparent;color:#555;white-space:nowrap;cursor:pointer;}
.fb.on{background:#cdd6f4;color:#0d0d1a;border-color:#cdd6f4;}
.stock-list{}
.si{display:flex;align-items:center;padding:8px 12px;border-bottom:0.5px solid #1a1a2a;cursor:pointer;}
.si:active{background:#1a1a2e;}
.si-left{flex:1;min-width:0;}
.si-ticker{font-size:12px;font-weight:500;color:#cdd6f4;}
.si-kr{font-size:10px;color:#555;}
.si-sec{font-size:9px;color:#333;margin-top:1px;}
.si-right{text-align:right;}
.si-chg{font-size:12px;font-weight:500;}
.si-price{font-size:10px;color:#555;}

/* 상세 화면 */
.detail-screen{display:none;flex-direction:column;height:100%;}
.detail-screen.show{display:flex;}
.detail-header{background:#1a1a2e;padding:8px 12px;border-bottom:0.5px solid #2a2a3e;display:flex;align-items:center;gap:8px;flex-shrink:0;}
.back-btn{font-size:20px;color:#cdd6f4;cursor:pointer;line-height:1;padding:0 4px;}
.detail-title{font-size:13px;font-weight:500;color:#cdd6f4;}
.detail-body{flex:1;overflow-y:auto;padding:10px 12px;}
.det-name{font-size:16px;font-weight:500;}
.det-kr{font-size:11px;color:#555;margin-bottom:3px;}
.det-chg{font-size:20px;font-weight:500;margin-bottom:2px;}
.det-price{font-size:13px;color:#888;margin-bottom:8px;}
.det-chart{height:80px;background:#1a1a2e;border-radius:6px;margin-bottom:8px;overflow:hidden;}
.det-tabs{display:flex;border-bottom:0.5px solid #2a2a3e;margin-bottom:8px;}
.det-tab{flex:1;text-align:center;font-size:10px;padding:5px 0;color:#555;border-bottom:2px solid transparent;cursor:pointer;}
.det-tab.on{color:#cdd6f4;border-bottom-color:#cdd6f4;}
.det-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:6px;}
.det-stat{background:#1a1a2e;border-radius:6px;padding:7px 8px;}
.det-sl{font-size:9px;color:#555;margin-bottom:2px;}
.det-sv{font-size:12px;font-weight:500;}
.det-52{font-size:10px;color:#555;padding:5px 0;border-top:0.5px solid #2a2a3e;}

/* 투자 인사이트 */
.insight-section{padding:8px 10px;}
.section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;}
.section-title{font-size:12px;font-weight:500;}
.scan-btn{font-size:9px;padding:3px 8px;border-radius:4px;border:0.5px solid #2a2a3e;background:transparent;color:#888;cursor:pointer;}
.pot-card{background:#1a1a2e;border-radius:6px;padding:8px 10px;margin-bottom:6px;border:0.5px solid #2a2a3e;}
.pot-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:4px;}
.pot-ticker{font-size:12px;font-weight:500;}
.pot-name{font-size:9px;color:#555;}
.pot-chg{font-size:11px;font-weight:500;}
.pot-tags{display:flex;gap:3px;margin-bottom:4px;flex-wrap:wrap;}
.pot-tag{font-size:8px;padding:1px 5px;border-radius:3px;background:rgba(83,74,183,.12);color:#534AB7;}
.pot-country{font-size:8px;padding:1px 5px;border-radius:3px;background:rgba(39,174,96,.1);color:#27ae60;}
.pot-summary{font-size:10px;color:#888;line-height:1.4;margin-bottom:4px;}
.pot-metrics{display:grid;grid-template-columns:1fr 1fr;gap:3px;margin-bottom:4px;}
.pot-metric{background:#0d0d1a;border-radius:3px;padding:3px 5px;}
.pot-ml{font-size:8px;color:#555;}
.pot-mv{font-size:10px;font-weight:500;}
.pot-score-row{display:flex;align-items:center;gap:6px;}
.pot-score-track{flex:1;height:3px;background:#0d0d1a;border-radius:2px;overflow:hidden;}
.pot-score-fill{height:100%;border-radius:2px;background:#27ae60;}
.pot-score-val{font-size:10px;font-weight:500;color:#27ae60;}

.sec-card{background:#1a1a2e;border-radius:6px;padding:8px 10px;margin-bottom:6px;border:0.5px solid #2a2a3e;}
.sec-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:5px;}
.sec-name{font-size:12px;font-weight:500;}
.sec-chg{font-size:10px;}
.sec-score-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:5px;}
.sec-score{font-size:16px;font-weight:500;}
.sec-badge{font-size:9px;padding:1px 6px;border-radius:3px;font-weight:500;}
.sec-bars{}
.sec-bar-row{display:flex;align-items:center;gap:5px;margin-bottom:2px;}
.sec-bar-lbl{font-size:8px;color:#555;width:40px;flex-shrink:0;}
.sec-bar-track{flex:1;height:3px;background:#0d0d1a;border-radius:2px;overflow:hidden;}
.sec-bar-fill{height:100%;border-radius:2px;}
.sec-bar-val{font-size:8px;font-weight:500;width:18px;text-align:right;}

/* 디지털 실물 자산 */
.asset-subtabs{display:flex;background:#1a1a2e;border-bottom:0.5px solid #2a2a3e;flex-shrink:0;}
.asset-subtab{flex:1;text-align:center;padding:5px 0;font-size:9px;color:#555;border-bottom:2px solid transparent;cursor:pointer;}
.asset-subtab.on{color:#cdd6f4;border-bottom-color:#cdd6f4;}
.coin-card{background:#1a1a2e;border-radius:6px;padding:8px 10px;margin-bottom:5px;border:0.5px solid #2a2a3e;display:flex;align-items:center;gap:8px;}
.coin-icon{width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:500;flex-shrink:0;}
.coin-info{flex:1;}
.coin-name{font-size:12px;font-weight:500;}
.coin-sym{font-size:9px;color:#555;}
.coin-price{font-size:12px;font-weight:500;margin-top:2px;}
.coin-right{text-align:right;}
.coin-chg{font-size:12px;font-weight:500;}
.coin-mcap{font-size:9px;color:#555;margin-top:2px;}
.commodity-card{background:#1a1a2e;border-radius:6px;padding:8px 10px;margin-bottom:5px;border:0.5px solid #2a2a3e;}
.com-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:5px;}
.com-name{font-size:11px;font-weight:500;}
.com-right{text-align:right;}
.com-price{font-size:11px;font-weight:500;}
.com-chg{font-size:10px;font-weight:500;}
.com-chart{height:50px;background:#0d0d1a;border-radius:3px;overflow:hidden;}

/* 뉴스 */
.news-item{padding:8px 12px;border-bottom:0.5px solid #1a1a2a;}
.news-hl{font-size:12px;font-weight:500;line-height:1.4;margin-bottom:3px;}
.news-meta{display:flex;align-items:center;gap:4px;}
.news-src{font-size:9px;color:#444;}
.news-badge{font-size:8px;padding:1px 5px;border-radius:3px;font-weight:500;}
.nb-pos{background:rgba(39,174,96,.12);color:#27ae60;}
.nb-neg{background:rgba(231,76,60,.12);color:#e74c3c;}
.nb-neu{background:#1a1a2e;color:#555;}
.fig-item{padding:8px 12px;border-bottom:0.5px solid #1a1a2a;}
.fig-top{display:flex;align-items:center;gap:6px;margin-bottom:4px;}
.fig-av{width:24px;height:24px;border-radius:50%;background:#1a1a2e;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:500;border:0.5px solid #2a2a3e;flex-shrink:0;}
.fig-name{font-size:11px;font-weight:500;}
.fig-role{font-size:9px;color:#555;}
.fig-time{font-size:9px;color:#333;margin-left:auto;}
.fig-quote{font-size:10px;color:#aaa;line-height:1.5;padding:4px 6px;background:#1a1a2e;border-left:2px solid #2a2a3e;border-radius:0 3px 3px 0;}

/* 하단 탭바 */
.navbar{height:52px;background:#1a1a2e;border-top:0.5px solid #2a2a3e;display:flex;align-items:center;justify-content:space-around;flex-shrink:0;padding-bottom:env(safe-area-inset-bottom);}
.nav-item{display:flex;flex-direction:column;align-items:center;gap:2px;cursor:pointer;padding:4px 12px;}
.nav-item svg{width:20px;height:20px;stroke:#555;fill:none;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round;}
.nav-item.on svg{stroke:#cdd6f4;}
.nav-lbl{font-size:9px;color:#555;}
.nav-item.on .nav-lbl{color:#cdd6f4;}

/* 화면 전환 */
.screen{display:none;flex-direction:column;height:100%;overflow:hidden;}
.screen.active{display:flex;}

/* 로딩 */
.loading{text-align:center;padding:30px;color:#555;font-size:12px;}
</style>
</head>
<body>

<!-- 헤더 -->
<div class="header">
  <div class="header-left">
    <div class="title">Kang's View</div>
    <div class="maker">by 2.i.n.7.u.n</div>
  </div>
  <div class="header-right">
    <div class="update-time" id="update-time"></div>
    <button class="refresh-btn" onclick="refreshAll()">새로고침</button>
  </div>
</div>

<!-- 미국주식 화면 -->
<div class="screen active" id="screen-stock">
  <div class="subtab-bar">
    <div class="subtab on" onclick="switchMarket('sp500',this)">S&P 500</div>
    <div class="subtab" onclick="switchMarket('nasdaq',this)">나스닥</div>
    <div class="subtab" onclick="switchMarket('kospi',this)">코스피</div>
    <div class="subtab" onclick="switchMarket('kosdaq',this)">코스닥</div>
  </div>
  <div class="sum-bar" id="sum-bar">
    <div class="sum-item"><span class="sum-val pos" id="sum-up">▲ -</span><span class="sum-lbl">상승</span></div>
    <div class="sum-div"></div>
    <div class="sum-item"><span class="sum-val neg" id="sum-dn">▼ -</span><span class="sum-lbl">하락</span></div>
    <div class="sum-div"></div>
    <div class="sum-item"><span class="sum-val" id="sum-avg" style="color:#888;">-</span><span class="sum-lbl">평균</span></div>
    <div class="sum-div"></div>
    <div class="sum-item"><span class="sum-val" id="sum-total" style="color:#cdd6f4;">-</span><span class="sum-lbl">전체</span></div>
  </div>
  <!-- 히트맵 -->
  <div class="content" id="heatmap-view">
    <div class="heatmap-wrap">
      <div class="hm-grid" id="hm-grid">
        <div class="loading">데이터 로딩 중...</div>
      </div>
    </div>
  </div>
  <!-- 종목 리스트 (히트맵 아래 스크롤) -->
  <div style="border-top:0.5px solid #2a2a3e;">
    <div class="search-bar">
      <input class="search-input" type="text" placeholder="티커 또는 기업명 검색..." id="stock-search" oninput="filterStocks()">
    </div>
    <div class="filter-bar">
      <button class="fb on" onclick="filterSort('chg_desc',this)">등락률↓</button>
      <button class="fb" onclick="filterSort('chg_asc',this)">등락률↑</button>
      <button class="fb" onclick="filterSort('name',this)">가나다</button>
    </div>
    <div class="stock-list" id="stock-list" style="max-height:200px;overflow-y:auto;">
      <div class="loading">로딩 중...</div>
    </div>
  </div>
</div>

<!-- 자산 화면 -->
<div class="screen" id="screen-asset">
  <div class="asset-subtabs">
    <div class="asset-subtab on" onclick="switchAsset('coin',this)">코인</div>
    <div class="asset-subtab" onclick="switchAsset('commodity',this)">귀금속·원자재</div>
    <div class="asset-subtab" onclick="switchAsset('fx',this)">환율</div>
  </div>
  <div class="content">
    <!-- 코인 -->
    <div id="asset-coin" style="padding:8px 10px;">
      <div class="loading">코인 데이터 로딩 중...</div>
    </div>
    <!-- 귀금속·원자재 -->
    <div id="asset-commodity" style="padding:8px 10px;display:none;">
      <div class="loading">원자재 데이터 로딩 중...</div>
    </div>
    <!-- 환율 -->
    <div id="asset-fx" style="padding:8px 10px;display:none;">
      <div class="loading">환율 데이터 로딩 중...</div>
    </div>
  </div>
</div>

<!-- 투자 인사이트 화면 -->
<div class="screen" id="screen-insight">
  <div class="content">
    <div class="insight-section">
      <div class="section-header">
        <div class="section-title">잠재주 발굴</div>
        <div style="display:flex;gap:4px;align-items:center;">
          <div class="filter-bar" style="padding:0;border:none;background:transparent;">
            <button class="fb on" onclick="filterPot('전체',this)">전체</button>
            <button class="fb" onclick="filterPot('미국',this)">미국</button>
            <button class="fb" onclick="filterPot('국내',this)">국내</button>
          </div>
          <button class="scan-btn">전체 조회</button>
        </div>
      </div>
      <div class="filter-bar" style="padding:0 0 6px;">
        <button class="fb on" onclick="filterTheme('전체',this)">전체</button>
        <button class="fb" onclick="filterTheme('AI',this)">AI</button>
        <button class="fb" onclick="filterTheme('양자컴퓨터',this)">양자컴퓨터</button>
        <button class="fb" onclick="filterTheme('2차전지',this)">2차전지</button>
        <button class="fb" onclick="filterTheme('바이오',this)">바이오</button>
        <button class="fb" onclick="filterTheme('우주',this)">우주</button>
      </div>
      <div id="pot-list"></div>
    </div>
    <div style="height:0.5px;background:#2a2a3e;margin:0 10px;"></div>
    <div class="insight-section">
      <div class="section-header">
        <div class="section-title">섹터 전망</div>
        <button class="scan-btn">전체 조회</button>
      </div>
      <div class="filter-bar" style="padding:0 0 6px;">
        <button class="fb on" onclick="sortSector('score',this)">종합점수순</button>
        <button class="fb" onclick="sortSector('chg',this)">등락률순</button>
        <button class="fb" onclick="sortSector('inflow',this)">자금유입순</button>
      </div>
      <div id="sector-list"></div>
    </div>
  </div>
</div>

<!-- 뉴스 화면 -->
<div class="screen" id="screen-news">
  <div class="subtab-bar">
    <div class="subtab on" onclick="switchNews('news',this)">시장 뉴스</div>
    <div class="subtab" onclick="switchNews('figure',this)">인물 발언</div>
  </div>
  <div class="content">
    <div id="news-list"></div>
    <div id="figure-list" style="display:none;"></div>
  </div>
</div>

<!-- 상세 화면 (오버레이) -->
<div id="detail-overlay" style="display:none;position:absolute;top:0;left:0;width:100%;height:100%;background:#0d0d1a;z-index:100;display:none;flex-direction:column;">
  <div class="detail-header">
    <span class="back-btn" onclick="closeDetail()">&#8592;</span>
    <span class="detail-title">기업 정보</span>
  </div>
  <div class="detail-body">
    <div id="detail-content"></div>
  </div>
</div>

<!-- 하단 탭바 -->
<div class="navbar">
  <div class="nav-item on" onclick="switchTab('stock',this)">
    <svg viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
    <span class="nav-lbl">주식</span>
  </div>
  <div class="nav-item" onclick="switchTab('asset',this)">
    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 8v8M8 12h8"/></svg>
    <span class="nav-lbl">자산</span>
  </div>
  <div class="nav-item" onclick="switchTab('insight',this)">
    <svg viewBox="0 0 24 24"><path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
    <span class="nav-lbl">인사이트</span>
  </div>
  <div class="nav-item" onclick="switchTab('news',this)">
    <svg viewBox="0 0 24 24"><path d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
    <span class="nav-lbl">뉴스</span>
  </div>
</div>

<script>
// ── 데이터 ──────────────────────────────────────────
const MARKETS = {
  sp500: {
    name: "S&P 500",
    heatmap: [
      {sector:"Technology",color:"#1a2a1a",stocks:[
        {t:"MSFT",k:"마이크로소프트",c:1.11,p:415.20},
        {t:"AAPL",k:"애플",c:-0.37,p:189.30},
        {t:"NVDA",k:"엔비디아",c:0.47,p:875.40},
        {t:"AMD",k:"에이엠디",c:2.60,p:155.70},
      ]},
      {sector:"Communication",color:"#2a1a1a",stocks:[
