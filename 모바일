    </div>
    <div id="det-price">
      <div class="det-grid">
        <div class="det-stat"><div class="det-sl">시가(전일)</div><div class="det-sv">${priceStr}</div></div>
        <div class="det-stat"><div class="det-sl">고가</div><div class="det-sv" style="color:#27ae60;">${fmtPrice(price*1.008, isKr)}</div></div>
        <div class="det-stat"><div class="det-sl">저가</div><div class="det-sv" style="color:#e74c3c;">${fmtPrice(price*0.992, isKr)}</div></div>
        <div class="det-stat"><div class="det-sl">거래량</div><div class="det-sv">58.3M</div></div>
        <div class="det-stat"><div class="det-sl">시가총액</div><div class="det-sv">${isKr ? '₩' : '$'}${(price * 5e9 / (isKr?1e12:1e9)).toFixed(1)}${isKr?'T':'B'}</div></div>
        <div class="det-stat"><div class="det-sl">PER</div><div class="det-sv">28.4x</div></div>
      </div>
      <div class="det-52">52주 고가: ${fmtPrice(price*1.15,isKr)} | 저가: ${fmtPrice(price*0.78,isKr)}</div>
    </div>
    <div id="det-earnings" style="display:none;"><div style="padding:10px;color:#555;font-size:11px;">실적 데이터 — 실제 앱에서는 yfinance로 실시간 제공</div></div>
    <div id="det-inst" style="display:none;"><div style="padding:10px;color:#555;font-size:11px;">기관 보유 현황 — 실제 앱에서는 yfinance로 실시간 제공</div></div>
    <div id="det-insider" style="display:none;"><div style="padding:10px;color:#555;font-size:11px;">내부자 거래 — 실제 앱에서는 yfinance로 실시간 제공</div></div>
  `;
}

function closeDetail() {
  document.getElementById('detail-overlay').style.display = 'none';
}

function switchDetTab(tab, el) {
  document.querySelectorAll('.det-tab').forEach(t => t.classList.remove('on'));
  el.classList.add('on');
  ['price','earnings','inst','insider'].forEach(t => {
    document.getElementById('det-' + t).style.display = t === tab ? 'block' : 'none';
  });
}

// ── 투자 인사이트 ─────────────────────────────────
function renderPotential() {
  let data = POTENTIAL.filter(p => {
    const countryOk = currentPotCountry === '전체' || p.country === currentPotCountry;
    const themeOk   = currentTheme === '전체' || p.theme.includes(currentTheme);
    return countryOk && themeOk;
  });
  const isKr = p => p.country === '국내';
  let html = data.map(p => `
    <div class="pot-card">
      <div class="pot-top">
        <div><div class="pot-ticker">${p.t}</div><div class="pot-name">${p.k}</div></div>
        <div style="text-align:right;">
          <div class="pot-chg" style="color:${cc(p.c)};">${fmtChg(p.c)}</div>
          <div style="font-size:9px;color:#555;">${fmtPrice(p.p, isKr(p))}</div>
        </div>
      </div>
      <div class="pot-tags">
        <span class="pot-country">${p.country}</span>
        ${p.theme.map(t => `<span class="pot-tag">${t}</span>`).join('')}
      </div>
      <div class="pot-summary">${p.summary}</div>
      <div class="pot-metrics">
        <div class="pot-metric"><div class="pot-ml">매출 성장률</div><div class="pot-mv pos">+${p.growth}%</div></div>
        <div class="pot-metric"><div class="pot-ml">52주 위치</div><div class="pot-mv">${p.pos52}%</div></div>
      </div>
      <div class="pot-score-row">
        <span style="font-size:9px;color:#555;">잠재력</span>
        <div class="pot-score-track"><div class="pot-score-fill" style="width:${p.score}%;"></div></div>
        <span class="pot-score-val">${p.score}점</span>
      </div>
    </div>`).join('');
  document.getElementById('pot-list').innerHTML = html || '<div class="loading">해당 조건의 종목이 없습니다.</div>';
}

function filterPot(country, el) {
  currentPotCountry = country;
  document.querySelectorAll('#screen-insight .filter-bar:first-of-type .fb').forEach(b => b.classList.remove('on'));
  el.classList.add('on');
  renderPotential();
}

function filterTheme(theme, el) {
  currentTheme = theme;
  el.parentElement.querySelectorAll('.fb').forEach(b => b.classList.remove('on'));
  el.classList.add('on');
  renderPotential();
}

function renderSectors() {
  let data = [...SECTORS];
  if (currentSectorSort === 'chg')    data.sort((a,b) => b.chg - a.chg);
  else if (currentSectorSort === 'inflow') data.sort((a,b) => b.inflow - a.inflow);
  else data.sort((a,b) => b.score - a.score);

  let html = data.map((s,i) => {
    const sc = s.score >= 70 ? '#27ae60' : (s.score < 40 ? '#e74c3c' : '#854F0B');
    const bs = s.badge === '급상승' || s.badge === '상승중'
      ? 'background:rgba(39,174,96,.15);color:#27ae60;'
      : (s.badge === '침체' ? 'background:rgba(231,76,60,.15);color:#e74c3c;' : 'background:#1e1e2e;color:#555;');
    const bars = [
      {l:'성장성',k:'growth'},{l:'자금유입',k:'inflow'},{l:'테마인기',k:'theme'},{l:'리스크',k:'risk'}
    ].map(b => {
      const bc = b.k === 'risk' ? (s[b.k]>=60?'#e74c3c':'#27ae60') : (s[b.k]>=60?'#27ae60':'#854F0B');
      return `<div class="sec-bar-row">
        <span class="sec-bar-lbl">${b.l}</span>
        <div class="sec-bar-track"><div class="sec-bar-fill" style="width:${s[b.k]}%;background:${bc};"></div></div>
        <span class="sec-bar-val" style="color:${bc};">${s[b.k]}</span>
      </div>`;
    }).join('');
    return `<div class="sec-card">
      <div class="sec-top">
        <div><div class="sec-name">${s.name}</div><div class="sec-chg" style="color:${cc(s.chg)};">${fmtChg(s.chg)} 이번주</div></div>
        <span style="font-size:9px;color:#444;">#${i+1}</span>
      </div>
      <div class="sec-score-row">
        <span class="sec-score" style="color:${sc};">${s.score}점</span>
        <span class="sec-badge" style="${bs}">${s.badge}</span>
      </div>
      ${bars}
    </div>`;
  }).join('');
  document.getElementById('sector-list').innerHTML = html;
}

function sortSector(sort, el) {
  currentSectorSort = sort;
  el.parentElement.querySelectorAll('.fb').forEach(b => b.classList.remove('on'));
  el.classList.add('on');
  renderSectors();
}

