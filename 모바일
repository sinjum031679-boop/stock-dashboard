// ── 유틸 ──────────────────────────────────────────
function cc(v) { return v >= 0 ? '#27ae60' : '#e74c3c'; }
function fmtChg(v) { return (v >= 0 ? '+' : '') + v.toFixed(2) + '%'; }
function fmtPrice(v, isKr) {
  if (isKr) return v >= 1000 ? v.toLocaleString() + '원' : v.toFixed(3);
  return v >= 100 ? '$' + v.toLocaleString() : '$' + v.toFixed(2);
}
function cellBg(c) {
  if (c > 2)  return '#2ecc71';
  if (c > 0)  return '#27ae60';
  if (c > -2) return '#c0392b';
  return '#a32d2d';
}

// ── 탭 전환 ─────────────────────────────────────
function switchTab(tab, el) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('on'));
  document.getElementById('screen-' + tab).classList.add('active');
  el.classList.add('on');
}

function switchMarket(market, el) {
  currentMarket = market;
  document.querySelectorAll('.subtab').forEach(t => t.classList.remove('on'));
  el.classList.add('on');
  renderHeatmap();
  renderStockList();
}

function switchAsset(type, el) {
  document.querySelectorAll('.asset-subtab').forEach(t => t.classList.remove('on'));
  el.classList.add('on');
  ['coin','commodity','fx'].forEach(t => {
    document.getElementById('asset-' + t).style.display = t === type ? 'block' : 'none';
  });
}

function switchNews(type, el) {
  document.querySelectorAll('.subtab').forEach(t => t.classList.remove('on'));
  el.classList.add('on');
  document.getElementById('news-list').style.display = type === 'news' ? 'block' : 'none';
  document.getElementById('figure-list').style.display = type === 'figure' ? 'block' : 'none';
}

// ── 히트맵 렌더링 ────────────────────────────────
function renderHeatmap() {
  const market = MARKETS[currentMarket];
  const grid = document.getElementById('hm-grid');
  let html = '';
  let up = 0, dn = 0, total = 0, sumChg = 0;

  market.heatmap.forEach(sec => {
    html += `<div class="hm-sector" style="background:${sec.color};">
      <span class="hm-sec-lbl">${sec.sector}</span>
      <div class="hm-cells">`;
    sec.stocks.forEach(s => {
      up += s.c > 0 ? 1 : 0;
      dn += s.c < 0 ? 1 : 0;
      total++;
      sumChg += s.c;
      const isKr = currentMarket === 'kospi' || currentMarket === 'kosdaq';
      html += `<div class="hm-cell" style="background:${cellBg(s.c)};" onclick="openDetail('${s.t}','${s.k}',${s.c},${s.p},${isKr})">
        <span class="hm-t">${s.t}</span>
        <span class="hm-k">${s.k}</span>
        <span class="hm-p">${fmtChg(s.c)}</span>
      </div>`;
    });
    html += '</div></div>';
  });

  grid.innerHTML = html;
  document.getElementById('sum-up').textContent   = '▲ ' + up;
  document.getElementById('sum-dn').textContent   = '▼ ' + dn;
  const avg = sumChg / total;
  const avgEl = document.getElementById('sum-avg');
  avgEl.textContent = fmtChg(avg);
  avgEl.style.color = cc(avg);
  document.getElementById('sum-total').textContent = total;
}

// ── 종목 리스트 ──────────────────────────────────
function renderStockList() {
  const market = MARKETS[currentMarket];
  let stocks = [...market.allStocks];
  const q = (document.getElementById('stock-search') || {}).value || '';
  if (q) stocks = stocks.filter(s => s.t.toLowerCase().includes(q.toLowerCase()) || s.k.includes(q));
  if (currentSort === 'chg_desc') stocks.sort((a,b) => b.c - a.c);
  else if (currentSort === 'chg_asc') stocks.sort((a,b) => a.c - b.c);
  else stocks.sort((a,b) => a.k.localeCompare(b.k));

  const isKr = currentMarket === 'kospi' || currentMarket === 'kosdaq';
  let html = stocks.map(s => `
    <div class="si" onclick="openDetail('${s.t}','${s.k}',${s.c},${s.p},${isKr})">
      <div class="si-left">
        <div class="si-ticker">${s.t}</div>
        <div class="si-kr">${s.k}</div>
        <div class="si-sec">${s.s}</div>
      </div>
      <div class="si-right">
        <div class="si-chg" style="color:${cc(s.c)};">${fmtChg(s.c)}</div>
        <div class="si-price">${fmtPrice(s.p, isKr)}</div>
      </div>
    </div>`).join('');
  document.getElementById('stock-list').innerHTML = html || '<div class="loading">검색 결과 없음</div>';
}

function filterStocks() { renderStockList(); }
function filterSort(sort, el) {
  currentSort = sort;
  document.querySelectorAll('.filter-bar .fb').forEach(b => b.classList.remove('on'));
  el.classList.add('on');
  renderStockList();
}

